# Supabase — https://supabase.com/dashboard/project/uhssspbmgsijvygrxvaw/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://uhssspbmgsijvygrxvaw.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Server-only — never expose to the browser or commit to git
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Or new-format secret key:
# SUPABASE_SECRET_KEY=sb_secret_...

# Database — enables `npm run db:migrate` / `npm run db:bootstrap` without service role
# Dashboard → Project Settings → Database
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.uhssspbmgsijvygrxvaw.supabase.co:5432/postgres
SUPABASE_DB_PASSWORD=

# Fingerprint of the sole admin access key (set after running scripts/create-admin-account.mjs)
ADMIN_FINGERPRINT=
NEXT_PUBLIC_ADMIN_FINGERPRINT=

# Copy to .env.local for local dev:
# cp .env.example .env.local