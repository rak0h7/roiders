# Supabase — Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Server-only — never expose to the browser or commit to git
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Or new-format secret key:
# SUPABASE_SECRET_KEY=sb_secret_...

# Database — enables npm run db:migrate / db:bootstrap / login Postgres fallback
# Dashboard → Project Settings → Database
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
SUPABASE_DB_PASSWORD=
# Vercel may inject these automatically:
# POSTGRES_URL=
# POSTGRES_URL_NON_POOLING=
# POSTGRES_HOST=
# POSTGRES_USER=
# POSTGRES_PASSWORD=

# Management API — alternative to direct Postgres for db:migrate
# npx supabase login → copy access token
# SUPABASE_ACCESS_TOKEN=

# Fingerprint of the sole admin access key (set after npm run create-admin)
ADMIN_FINGERPRINT=
NEXT_PUBLIC_ADMIN_FINGERPRINT=

# Encrypts escrowed access keys in access_key_vault (32+ random chars; server-only)
ACCESS_KEY_VAULT_SECRET=

# Canonical production URL (sitemap, OG tags, robots)
NEXT_PUBLIC_SITE_URL=https://roiders.club

# Copy to .env.local for local dev:
# cp .env.example .env.local